<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <!-- getscribe.dev social card. EVERGREEN: this file must never contain a
       version string — it is rasterised into og.png and platforms cache the
       pixels. The eyebrow is a tagline, never "vX.Y.Z". -->
  <defs>
    <radialGradient id="g1" cx="20%" cy="0%" r="80%">
      <stop offset="0%" stop-color="#ffb86b" stop-opacity="0.18"/>
      <stop offset="60%" stop-color="#ffb86b" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="g2" cx="100%" cy="100%" r="70%">
      <stop offset="0%" stop-color="#7dd3fc" stop-opacity="0.14"/>
      <stop offset="60%" stop-color="#7dd3fc" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <rect width="1200" height="630" fill="#0e0f12"/>
  <rect width="1200" height="630" fill="url(#g1)"/>
  <rect width="1200" height="630" fill="url(#g2)"/>

  <!-- Decorative graph nodes + edges in upper-right corner -->
  <g stroke="#ffb86b" stroke-width="1.5" opacity="0.18">
    <line x1="950" y1="90" x2="1040" y2="160"/>
    <line x1="1040" y1="160" x2="1110" y2="100"/>
    <line x1="1040" y1="160" x2="990" y2="240"/>
    <line x1="990" y1="240" x2="900" y2="200"/>
    <line x1="900" y1="200" x2="950" y2="90"/>
    <line x1="1110" y1="100" x2="1130" y2="190"/>
  </g>
  <g fill="#ffb86b" opacity="0.65">
    <circle cx="950" cy="90" r="5"/>
    <circle cx="1040" cy="160" r="6"/>
    <circle cx="1110" cy="100" r="4"/>
    <circle cx="990" cy="240" r="5"/>
    <circle cx="900" cy="200" r="4"/>
    <circle cx="1130" cy="190" r="3"/>
  </g>

  <!-- Eyebrow — tagline only, NEVER a version -->
  <text x="80" y="155" font-family="ui-monospace, SF Mono, Menlo, monospace"
        font-size="22" letter-spacing="3" fill="#6b6f78">SCRIBE — SINGLE-BINARY GO CLI</text>

  <!-- Headline -->
  <text x="80" y="270" font-family="Iowan Old Style, Palatino, Georgia, serif"
        font-size="86" font-weight="400" fill="#e6e8ec">Your knowledge base,</text>
  <text x="80" y="370" font-family="Iowan Old Style, Palatino, Georgia, serif"
        font-size="86" font-style="italic" font-weight="400" fill="#ffb86b">written by your tools.</text>

  <!-- Lede -->
  <text x="80" y="440" font-family="-apple-system, Helvetica, Arial, sans-serif"
        font-size="26" fill="#9ba0aa">A single-binary CLI that mines your git repos,</text>
  <text x="80" y="478" font-family="-apple-system, Helvetica, Arial, sans-serif"
        font-size="26" fill="#9ba0aa">Claude Code &amp; Codex sessions &amp; self-sent links</text>
  <text x="80" y="516" font-family="-apple-system, Helvetica, Arial, sans-serif"
        font-size="26" fill="#9ba0aa">into a curated, semantically searchable wiki.</text>

  <!-- Footer URL -->
  <text x="80" y="585" font-family="ui-monospace, SF Mono, Menlo, monospace"
        font-size="22" fill="#ffb86b">getscribe.dev</text>
</svg>
